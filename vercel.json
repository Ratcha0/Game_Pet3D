{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/dashboard", "destination": "/dashboard.html" },
    { "source": "/game", "destination": "/game.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors 'self' https://likepoint2-0.web.app https://minipoint.likepoint.io http://localhost:8080;"
        },
        {
          "key": "X-Frame-Options",
          "value": "ALLOW-FROM https://likepoint2-0.web.app https://minipoint.likepoint.io http://localhost:8080"
        },
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        }
      ]
    }
  ]
}
